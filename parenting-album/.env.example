# ==============================================================
# 원우 앨범봇 — 환경변수 템플릿
# ==============================================================
# 이 파일은 Git에 커밋됩니다. 실제 값은 .env.local 에 저장하세요.
# Vercel 배포 시에는 대시보드 → Settings → Environment Variables 에 등록.
# GitHub Actions 에는 Repo → Settings → Secrets and variables 에 등록.
# ==============================================================

# --- [Phase 1] Kakao Webhook 보안 ---
# URL 쿼리파라미터로 전달될 시크릿 (아무 랜덤 문자열 32자 이상 권장)
KAKAO_WEBHOOK_SECRET=replace-with-random-32-char-string

# --- [Phase 1] 응답 메시지의 앨범 링크 ---
# 저장 완료 후 안내 메시지에 포함될 디지털 앨범 URL의 base 주소.
# 비워두면 Vercel이 자동 주입하는 VERCEL_URL(프로토콜 없음)을 사용.
# 커스텀 도메인을 쓴다면 여기에 https://your-domain.com 형태로 지정.
# PUBLIC_ALBUM_BASE_URL=https://focuskit-five.vercel.app

# --- [Phase 1 & 2] Notion ---
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion DB ID (URL에서 추출, 32자 hex)
NOTION_DB_RAW_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_USERS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_WEEKLY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_COMMENTS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- [Phase 1] Cloudinary ---
# https://console.cloudinary.com/ → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx
# 업로드될 폴더명 (선택, 기본: wonwoo-album)
CLOUDINARY_FOLDER=wonwoo-album

# --- [Phase 2] Gemini API ---
# https://aistudio.google.com/app/apikey 에서 발급 (무료)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- [Phase 3] Local PDF Build ---
# 로컬에서 PDF 빌드 시 출력 디렉토리
PDF_OUTPUT_DIR=./dist
# 원본 아카이브 시 복사할 로컬 경로 (외장하드 등)
ARCHIVE_LOCAL_PATH=/Volumes/Backup/wonwoo-album
