<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>{{cover.title}}</title>

<!--
  Fonts: 우선 Google Fonts + jsdelivr CDN.
  나중에 교보손글씨/마루부리로 바꾸고 싶으면 아래 @font-face의 src를
  로컬 fonts/ 폴더의 ttf/otf 경로(file:// absolute)로 교체하면 됨.
-->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Gaegu:wght@400;700&family=Gowun+Batang:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/pretendardvariable.min.css" rel="stylesheet">

<style>
  @page {
    size: A5;
    margin: 0;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Gowun Batang', 'Nanum Myeongjo', serif;
    color: #1a1814;
    background: #fdfaf1;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* 각 page는 A5 크기의 독립 페이지 */
  .page {
    width: 148mm;
    height: 210mm;
    padding: 12mm 10mm;
    page-break-after: always;
    page-break-inside: avoid;
    position: relative;
    overflow: hidden;
  }
  .page:last-of-type {
    page-break-after: auto;
  }

  /* ─────── 표지 ─────── */
  .cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(170deg, #fdfaf1 0%, #f5ecd6 100%);
  }
  .cover-title {
    font-family: 'Gaegu', cursive;
    font-size: 52pt;
    font-weight: 700;
    margin: 0 0 4mm;
    color: #2a2113;
    line-height: 1.2;
  }
  .cover-subtitle {
    font-family: 'Gowun Batang', serif;
    font-size: 16pt;
    color: #5c4e35;
    margin: 0 0 12mm;
  }
  .cover-date {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 10pt;
    color: #8a7d5f;
    letter-spacing: 0.1em;
  }
  .cover-ornament {
    width: 40mm;
    height: 1px;
    background: #b8a576;
    margin: 8mm 0;
  }

  /* ─────── 에세이 페이지 ─────── */
  .essay-page {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 30mm;
  }
  .week-label {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 9pt;
    color: #8a7d5f;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 4mm;
  }
  .week-title {
    font-family: 'Gaegu', cursive;
    font-size: 32pt;
    font-weight: 700;
    color: #2a2113;
    margin: 0 0 14mm;
    line-height: 1.15;
  }
  .week-essay {
    font-family: 'Gowun Batang', serif;
    font-size: 12pt;
    line-height: 2;
    color: #332b1c;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ─────── 표지 사진 ─────── */
  .cover-photo-wrap {
    width: 100mm;
    height: 120mm;
    margin: 10mm 0;
    overflow: hidden;
    border-radius: 2mm;
    box-shadow: 0 4mm 12mm rgba(0,0,0,0.15);
  }
  .cover-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─────── 월 소개 페이지 ─────── */
  .intro-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 30mm 14mm;
    background: #fdfaf1;
  }
  .intro-label {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 10pt;
    color: #8a7d5f;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 8mm;
  }
  .intro-headline {
    font-family: 'Gaegu', cursive;
    font-size: 42pt;
    font-weight: 700;
    color: #2a2113;
    margin-bottom: 12mm;
    line-height: 1.2;
  }
  .intro-stats {
    display: flex;
    gap: 8mm;
    margin-bottom: 10mm;
  }
  .intro-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .intro-stat-num {
    font-family: 'Gowun Batang', serif;
    font-size: 28pt;
    font-weight: 700;
    color: #8a5e2f;
  }
  .intro-stat-label {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 10pt;
    color: #786f60;
    margin-top: 1mm;
  }
  .intro-dates {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 11pt;
    color: #5c4e35;
  }

  /* ─────── 사진 페이지 공통 ─────── */
  .photo-page {
    display: flex;
    flex-direction: column;
    padding: 0;
    background: #fff;
  }
  .photo-slot {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    position: relative;
  }
  .photo-frame {
    flex: 1;
    overflow: hidden;
    min-height: 0;
    background: #f0ebe0;
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-caption {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 8pt;
    color: #5c4e35;
    padding: 2mm 4mm;
    background: #fdfaf1;
  }
  .photo-caption .author {
    font-weight: 600;
    color: #8a5e2f;
  }
  .photo-caption .content {
    display: block;
    margin-top: 0.5mm;
    font-style: italic;
    color: #332b1c;
  }

  /* ─────── T1: 풀블리드 1장 (기본, 가장 인상적) ─────── */
  .page.t1 .photo-frame { padding: 0; }

  /* ─────── T2: 사진 + 캡션형 (하단 캡션 크게) ─────── */
  .page.t2 .photo-frame {
    height: 160mm;
    flex: none;
  }
  .page.t2 .t2-caption {
    padding: 14mm 12mm;
    background: #fdfaf1;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .page.t2 .t2-caption .content {
    font-family: 'Gowun Batang', serif;
    font-size: 14pt;
    line-height: 1.8;
    color: #2a2113;
    font-style: italic;
    white-space: pre-wrap;
  }
  .page.t2 .t2-caption .meta {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 9pt;
    color: #8a7d5f;
    margin-top: 6mm;
  }
  .page.t2 .t2-caption .meta .author {
    font-weight: 600;
    color: #8a5e2f;
  }

  /* ─────── T3: 2장 균등 ─────── */
  .page.t3 {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 2mm;
    padding: 2mm;
    background: #fff;
  }
  .page.t3 .photo-slot { padding: 0; }

  /* ─────── T4: 3장 혼합 (상단 1 크게 + 하단 2 작게) ─────── */
  .page.t4 {
    display: grid;
    grid-template-rows: 2fr 1fr;
    grid-template-columns: 1fr 1fr;
    gap: 2mm;
    padding: 2mm;
    background: #fff;
  }
  .page.t4 .photo-slot:nth-child(1) {
    grid-column: 1 / -1;
  }

  /* ─────── T5: 4장 그리드 ─────── */
  .page.t5 {
    display: grid;
    grid-template-rows: 1fr 1fr;
    grid-template-columns: 1fr 1fr;
    gap: 2mm;
    padding: 2mm;
    background: #fff;
  }

  /* ─────── 회고 페이지 ─────── */
  .retro-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 15mm 12mm;
    background: linear-gradient(170deg, #f5ecd6 0%, #fdfaf1 100%);
    text-align: center;
  }
  .retro-hero {
    width: 100%;
    max-width: 110mm;
    height: 80mm;
    overflow: hidden;
    border-radius: 3mm;
    margin-bottom: 8mm;
    box-shadow: 0 3mm 10mm rgba(0,0,0,0.12);
  }
  .retro-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .retro-headline {
    font-family: 'Gaegu', cursive;
    font-size: 28pt;
    color: #2a2113;
    margin-bottom: 6mm;
    font-weight: 700;
  }
  .retro-summary {
    font-family: 'Gowun Batang', serif;
    font-size: 11pt;
    color: #332b1c;
    line-height: 1.9;
    max-width: 110mm;
    white-space: pre-wrap;
  }

  /* ─────── 뒷표지 ─────── */
  .back-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(170deg, #f5ecd6 0%, #fdfaf1 100%);
  }
  .back-note {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 9pt;
    color: #8a7d5f;
    max-width: 100mm;
    line-height: 1.8;
  }
  .back-url {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 8pt;
    color: #8a7d5f;
    margin-top: 6mm;
    letter-spacing: 0.05em;
  }
</style>
</head>
<body>

<!-- 표지 -->
<section class="page cover">
  <h1 class="cover-title">{{cover.title}}</h1>
  {{#if cover.coverPhotoUrl}}
    <div class="cover-photo-wrap">
      <img src="{{cover.coverPhotoUrl}}" alt="표지">
    </div>
  {{else}}
    <div class="cover-ornament"></div>
  {{/if}}
  <p class="cover-subtitle">{{cover.subtitle}}</p>
  <p class="cover-date">{{cover.dateLabel}}</p>
</section>

<!-- 월 소개 페이지 -->
<section class="page intro-page">
  <p class="intro-label">{{cover.dateLabel}}</p>
  {{#if intro.headline}}
    <h2 class="intro-headline">{{intro.headline}}</h2>
  {{/if}}
  <div class="intro-stats">
    <div class="intro-stat">
      <span class="intro-stat-num">{{intro.totalPhotos}}</span>
      <span class="intro-stat-label">사진</span>
    </div>
    <div class="intro-stat">
      <span class="intro-stat-num">{{intro.totalComments}}</span>
      <span class="intro-stat-label">댓글</span>
    </div>
  </div>
  <p class="intro-dates">{{intro.firstDate}} ~ {{intro.lastDate}}</p>
</section>

{{#each weeks}}
  {{!-- 에세이 페이지는 essay가 있을 때만 표시 --}}
  {{#if this.essay}}
  <section class="page essay-page">
    <p class="week-label">{{this.weekLabel}}</p>
    <h2 class="week-title">{{this.title}}</h2>
    <p class="week-essay">{{this.essay}}</p>
  </section>
  {{/if}}

  <!-- 사진 페이지 (템플릿별 분기) -->
  {{#each this.photoPages}}
    {{#if (eq this.template 'T2')}}
      {{!-- T2: 사진 + 큰 캡션 --}}
      <section class="page photo-page t2">
        {{#with (lookup this.slots 0)}}
          <div class="photo-frame">
            <img src="{{this.imageUrl}}" alt="{{this.alt}}">
          </div>
          <div class="t2-caption">
            {{#if this.content}}<div class="content">{{this.content}}</div>{{/if}}
            <div class="meta"><span class="author">{{this.author}}</span> · {{this.dateLabel}}</div>
          </div>
        {{/with}}
      </section>
    {{else if (eq this.template 'T3')}}
      {{!-- T3: 2장 균등 --}}
      <section class="page t3">
        {{#each this.slots}}
          <div class="photo-slot">
            <div class="photo-frame">
              <img src="{{this.imageUrl}}" alt="{{this.alt}}">
            </div>
          </div>
        {{/each}}
      </section>
    {{else if (eq this.template 'T4')}}
      {{!-- T4: 3장 혼합 (상단 1 + 하단 2) --}}
      <section class="page t4">
        {{#each this.slots}}
          <div class="photo-slot">
            <div class="photo-frame">
              <img src="{{this.imageUrl}}" alt="{{this.alt}}">
            </div>
          </div>
        {{/each}}
      </section>
    {{else if (eq this.template 'T5')}}
      {{!-- T5: 4장 그리드 --}}
      <section class="page t5">
        {{#each this.slots}}
          <div class="photo-slot">
            <div class="photo-frame">
              <img src="{{this.imageUrl}}" alt="{{this.alt}}">
            </div>
          </div>
        {{/each}}
      </section>
    {{else}}
      {{!-- T1 기본: 풀블리드 1장 --}}
      <section class="page photo-page t1">
        {{#with (lookup this.slots 0)}}
          <div class="photo-slot">
            <div class="photo-frame">
              <img src="{{this.imageUrl}}" alt="{{this.alt}}">
            </div>
            <div class="photo-caption">
              <span class="author">{{this.author}}</span>
              &nbsp;·&nbsp;
              <span>{{this.dateLabel}}</span>
              {{#if this.content}}
                <span class="content">"{{this.content}}"</span>
              {{/if}}
            </div>
          </div>
        {{/with}}
      </section>
    {{/if}}
  {{/each}}
{{/each}}

<!-- 회고 페이지 -->
<section class="page retro-page">
  {{#if retrospect.heroPhotoUrl}}
    <div class="retro-hero">
      <img src="{{retrospect.heroPhotoUrl}}" alt="회고">
    </div>
  {{/if}}
  {{#if retrospect.headline}}
    <h2 class="retro-headline">{{retrospect.headline}}</h2>
  {{/if}}
  {{#if retrospect.summary}}
    <p class="retro-summary">{{retrospect.summary}}</p>
  {{/if}}
</section>

<!-- 뒷표지 -->
<section class="page back-cover">
  <p class="back-note">
    이 앨범의 사진과 영상, 가족들의 댓글은<br>
    디지털 버전에서 언제든 다시 볼 수 있어요.
  </p>
  {{#if backCover.url}}
    <p class="back-url">{{backCover.url}}</p>
  {{/if}}
</section>

</body>
</html>
