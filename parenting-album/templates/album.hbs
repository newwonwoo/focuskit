<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>{{cover.title}}</title>

<!--
  Fonts: 우선 Google Fonts + jsdelivr CDN.
  나중에 교보손글씨/마루부리로 바꾸고 싶으면 아래 @font-face의 src를
  로컬 fonts/ 폴더의 ttf/otf 경로(file:// absolute)로 교체하면 됨.
-->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Gaegu:wght@400;700&family=Gowun+Batang:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/pretendardvariable.min.css" rel="stylesheet">

<style>
  @page {
    size: A5;
    margin: 0;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Gowun Batang', 'Nanum Myeongjo', serif;
    color: #1a1814;
    background: #fdfaf1;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* 각 page는 A5 크기의 독립 페이지 */
  .page {
    width: 148mm;
    height: 210mm;
    padding: 12mm 10mm;
    page-break-after: always;
    page-break-inside: avoid;
    position: relative;
    overflow: hidden;
  }
  .page:last-of-type {
    page-break-after: auto;
  }

  /* ─────── 표지 ─────── */
  .cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(170deg, #fdfaf1 0%, #f5ecd6 100%);
  }
  .cover-title {
    font-family: 'Gaegu', cursive;
    font-size: 52pt;
    font-weight: 700;
    margin: 0 0 4mm;
    color: #2a2113;
    line-height: 1.2;
  }
  .cover-subtitle {
    font-family: 'Gowun Batang', serif;
    font-size: 16pt;
    color: #5c4e35;
    margin: 0 0 12mm;
  }
  .cover-date {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 10pt;
    color: #8a7d5f;
    letter-spacing: 0.1em;
  }
  .cover-ornament {
    width: 40mm;
    height: 1px;
    background: #b8a576;
    margin: 8mm 0;
  }

  /* ─────── 에세이 페이지 ─────── */
  .essay-page {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 30mm;
  }
  .week-label {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 9pt;
    color: #8a7d5f;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 4mm;
  }
  .week-title {
    font-family: 'Gaegu', cursive;
    font-size: 32pt;
    font-weight: 700;
    color: #2a2113;
    margin: 0 0 14mm;
    line-height: 1.15;
  }
  .week-essay {
    font-family: 'Gowun Batang', serif;
    font-size: 12pt;
    line-height: 2;
    color: #332b1c;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ─────── 사진 페이지 (1장/페이지, 풀 사이즈) ─────── */
  .photo-page {
    display: flex;
    flex-direction: column;
    padding: 0;
    background: #fff;
  }
  .photo-slot {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .photo-frame {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-caption {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 8pt;
    color: #5c4e35;
    padding: 3mm 5mm;
    background: #fdfaf1;
  }
  .photo-caption .author {
    font-weight: 600;
    color: #8a5e2f;
  }
  .photo-caption .content {
    display: block;
    margin-top: 0.5mm;
    font-style: italic;
    color: #332b1c;
  }

  /* ─────── 뒷표지 ─────── */
  .back-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(170deg, #f5ecd6 0%, #fdfaf1 100%);
  }
  .back-note {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 9pt;
    color: #8a7d5f;
    max-width: 100mm;
    line-height: 1.8;
  }
  .back-url {
    font-family: 'Pretendard Variable', sans-serif;
    font-size: 8pt;
    color: #8a7d5f;
    margin-top: 6mm;
    letter-spacing: 0.05em;
  }
</style>
</head>
<body>

<!-- 표지 -->
<section class="page cover">
  <h1 class="cover-title">{{cover.title}}</h1>
  <div class="cover-ornament"></div>
  <p class="cover-subtitle">{{cover.subtitle}}</p>
  <p class="cover-date">{{cover.dateLabel}}</p>
</section>

{{#each weeks}}
  <!-- 에세이 페이지 -->
  <section class="page essay-page">
    <p class="week-label">{{this.weekLabel}}</p>
    <h2 class="week-title">{{this.title}}</h2>
    <p class="week-essay">{{this.essay}}</p>
  </section>

  <!-- 사진 페이지들: 페이지당 2장 -->
  {{#each this.photoPages}}
    <section class="page photo-page">
      {{#each this.slots}}
        <div class="photo-slot">
          <div class="photo-frame">
            <img src="{{this.imageUrl}}" alt="{{this.alt}}">
          </div>
          <div class="photo-caption">
            <span class="author">{{this.author}}</span>
            &nbsp;·&nbsp;
            <span>{{this.dateLabel}}</span>
            {{#if this.content}}
              <span class="content">"{{this.content}}"</span>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </section>
  {{/each}}
{{/each}}

<!-- 뒷표지 -->
<section class="page back-cover">
  <p class="back-note">
    이 앨범의 사진과 영상, 가족들의 댓글은<br>
    디지털 버전에서 언제든 다시 볼 수 있어요.
  </p>
  {{#if backCover.url}}
    <p class="back-url">{{backCover.url}}</p>
  {{/if}}
</section>

</body>
</html>
